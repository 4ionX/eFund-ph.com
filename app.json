{
  "expo": {
    "name": "e-Fund",
    "slug": "efund",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "efund",
    "userInterfaceStyle": "automatic",

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aionx.eFund",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "eFund uses your camera only for scanning and capturing documents required for loan application and account verification.",
        "NSUserTrackingUsageDescription": "eFund uses tracking to improve app performance and provide a better user experience. No personal data is sold."
      }
    },

    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.aionx.eFund",
      "permissions": ["CAMERA"]
    },

    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "eFund uses tracking to improve app performance and provide personalized experience. No personal data is sold."
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "ae3b973f-1629-4d58-8092-eb29dd191a21"
      }
    },

    "owner": "aionx",

    "updates": {
      "url": "https://u.expo.dev/ae3b973f-1629-4d58-8092-eb29dd191a21",
      "fallbackToCacheTimeout": 0
    },

    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
